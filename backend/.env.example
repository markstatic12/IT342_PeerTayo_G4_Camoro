# ─────────────────────────────────────────────────────────────────────────────
# PeerTayo Backend — Environment Variables TEMPLATE
# Copy this file to .env and fill in your own values.
# .env is gitignored; .env.example is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# Database (Supabase connection pooler)
# Get this from: Supabase Dashboard → Settings → Database → Connection string → Session mode
DB_URL=jdbc:postgresql://<pooler-host>:5432/postgres?prepareThreshold=0
DB_USERNAME=postgres.<your-project-ref>
DB_PASSWORD=<your-supabase-password>

# JWT — generate a strong random hex string (min 32 bytes)
JWT_SECRET=<your-jwt-hex-secret>

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://10.0.2.2:8080
