<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Night theme intentionally inherits from Base.Theme.Peertayomobile
        since the entire app uses a dark design system matching the web.
        No overrides needed — the day/night split is all dark.
    -->
    <style name="Base.Theme.Peertayomobile" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <style name="Theme.Peertayomobile.Splash" parent="Theme.Peertayomobile.NoActionBar" />

    <!-- Strictly Dark theme for Evaluation Creation to avoid white pickers -->
    <style name="Theme.Peertayomobile.CreateEvaluation" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Force picker themes via Activity attributes -->
        <item name="materialCalendarTheme">@style/CustomDatePickerTheme</item>
        <item name="materialTimePickerTheme">@style/CustomTimePickerTheme</item>
    </style>

    <style name="CustomTimePickerTheme" parent="ThemeOverlay.Material3.MaterialTimePicker">
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/bg_primary</item>
        <item name="colorSurfaceVariant">#F1F5F9</item>
        <item name="colorOnSurfaceVariant">@color/bg_primary</item>
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/blue_light</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondaryContainer">#F1F5F9</item>
        <item name="colorOnSecondaryContainer">@color/bg_primary</item>
        <item name="colorTertiaryContainer">#F1F5F9</item>
        <item name="colorOnTertiaryContainer">@color/bg_primary</item>
    </style>

    <style name="CustomDatePickerTheme" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/bg_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_muted</item>
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>
</resources>