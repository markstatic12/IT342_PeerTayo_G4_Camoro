<?xml version="1.0" encoding="utf-8"?>
<!-- Web stat card top accent: blue #3b82f6 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#111827" />
            <stroke android:width="1dp" android:color="#12FFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:top="0dp" android:left="16dp" android:right="16dp" android:bottom="0dp">
        <shape>
            <solid android:color="#3B82F6" />
            <corners android:topLeftRadius="0dp" android:topRightRadius="0dp" android:bottomLeftRadius="2dp" android:bottomRightRadius="2dp" />
            <size android:height="2dp" />
        </shape>
    </item>
</layer-list>
