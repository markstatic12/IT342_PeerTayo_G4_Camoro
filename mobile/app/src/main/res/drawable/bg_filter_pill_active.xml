<?xml version="1.0" encoding="utf-8"?>
<!--
  bg_filter_pill_active.xml
  Active/selected state for filter tab pills — solid cyan fill.
  Matches web's active tab indicator: bg-blue-900/60 border-blue-500.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#0E7490" />
    <stroke android:width="1dp" android:color="#22D3EE" />
    <corners android:radius="6dp" />
</shape>
