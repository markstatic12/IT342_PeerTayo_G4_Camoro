<?xml version="1.0" encoding="utf-8"?>
<!-- Facilitator promo: orange tint matching web gh-alert style -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:startColor="#0F172A"
                android:centerColor="#1A0D1729"
                android:endColor="#111827"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="#38F97316" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
