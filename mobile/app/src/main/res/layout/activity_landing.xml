<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".landing.LandingActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/dark_bg">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/brand_logo_description"
                    android:src="@drawable/ic_peertayo_logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="PeerTayo"
                    style="@style/SectionTitleStyle"
                    android:textColor="@color/primary_text_color" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Peer Evaluation."
                style="@style/HeroTitleStyle"
                android:gravity="center"
                android:layout_marginTop="48dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reimagined"
                style="@style/HeroAccentStyle"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="for Real Teams."
                style="@style/HeroWarmStyle"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PeerTayo transforms how teams assess each other with structured, private, and actionable feedback. Built for classrooms, organizations, and collaborative groups."
                style="@style/SubtitleStyle"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGetStarted"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Get Started Free"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/dark_bg"
                android:backgroundTint="@color/primary_color"
                app:cornerRadius="28dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLearnMore"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="See How It Works"
                android:textSize="16sp"
                android:textColor="@color/secondary_text_color"
                android:backgroundTint="@android:color/transparent"
                app:strokeColor="@color/dark_border_hi"
                app:strokeWidth="1dp"
                app:cornerRadius="28dp"
                android:layout_marginBottom="32dp" />

            <!-- Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/statEvaluations"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500+"
                        style="@style/StatNumberStyle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Evaluations"
                        style="@style/StatLabelStyle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/statUsers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,000+"
                        style="@style/StatNumberStyle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Users"
                        style="@style/StatLabelStyle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/statTeams"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50+"
                        style="@style/StatNumberStyle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teams"
                        style="@style/StatLabelStyle" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Features Section -->
        <LinearLayout
            android:id="@+id/featuresSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/dark_surface">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Platform Features"
                style="@style/SectionLabelStyle"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Everything your team needs to evaluate well."
                style="@style/SectionTitleStyle"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="From private submissions to real-time analytics, PeerTayo equips both respondents and facilitators with the right tools."
                style="@style/SubtitleStyle"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeatures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp" />
        </LinearLayout>

        <!-- How It Works Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/dark_surface">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Process Flow"
                style="@style/SectionLabelStyle"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How PeerTayo Works"
                style="@style/SectionTitleStyle"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Four steps from setup to insight, built for speed and accountability."
                style="@style/SubtitleStyle"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHowItWorks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Final CTA Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/dark_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready to transform your team's evaluation process?"
                style="@style/CTATitleStyle"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join thousands of users already using PeerTayo for better team insights."
                style="@style/CTADescStyle"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Get Started Now"
                style="@style/Widget.AppCompat.Button"
                android:textColor="@color/dark_bg"
                android:backgroundTint="@color/primary_color"
                app:cornerRadius="28dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
