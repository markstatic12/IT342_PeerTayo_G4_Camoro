<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_results.xml
  GAP-01 FIX:
    • 4-stat strip: Evaluations Received / Overall Avg Score / Total Responses / Highest Criterion
    • Filter tabs: All / Highest / Most Recent  (matches web MyResultsPage)
    • Terminology aligned with web
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <!-- ── 4-Stat Strip ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <!-- Evaluations Received -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvReceivedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/cyan_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/results_stat_received" android:textColor="@color/text_muted"
                android:textSize="9sp" android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/border_card" />

        <!-- Overall Avg Score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvAverageScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/orange_accent"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/results_stat_avg" android:textColor="@color/text_muted"
                android:textSize="9sp" android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/border_card" />

        <!-- Total Responses -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvImprovedScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/green_success"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/results_stat_responses" android:textColor="@color/text_muted"
                android:textSize="9sp" android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/border_card" />

        <!-- Highest Criterion (4th stat — GAP-01) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">
            <TextView
                android:id="@+id/tvHighestCriterion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#A78BFA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/results_stat_highest"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>
    </LinearLayout>

    <!-- Archive Toggle (GAP-01) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Show Archived"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/plus_jakarta_sans" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchArchived"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- ── Filter Tabs: All / Highest / Most Recent ──────────────────── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/filter_all"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_on_cyan"
                android:background="@drawable/bg_filter_pill_active"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterHighest"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/filter_highest"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterRecent"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/filter_recent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="16dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Result Cards List ─────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_empty_chart"
            app:tint="@color/text_placeholder" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/results_empty"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</LinearLayout>
