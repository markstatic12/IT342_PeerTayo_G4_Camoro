<?xml version="1.0" encoding="utf-8"?>
<!-- Single row in the Recent Activity feed — mirrors web's act-item structure -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="10dp"
    android:gravity="top">

    <!-- Timeline column: dot + vertical line -->
    <LinearLayout
        android:layout_width="20dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginEnd="12dp">

        <View
            android:id="@+id/activityDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_activity_dot"
            android:layout_marginTop="3dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/border_card"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Body: title + message sub-text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvActivityTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvActivityMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
