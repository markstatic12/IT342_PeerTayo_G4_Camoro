<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Back Arrow + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Overall Score Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_greeting_card"
            android:padding="20dp"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvOverallScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cyan_primary"
                android:textSize="40sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/ 5.0"
                android:textColor="@color/text_muted"
                android:textSize="16sp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:id="@+id/tvResponseCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Criteria Breakdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Criteria Breakdown"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/criteriaContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp" />

        <!-- Comments Section -->
        <TextView
            android:id="@+id/tvCommentsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anonymous Feedback"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/commentsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvNoComments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No comments received yet."
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
