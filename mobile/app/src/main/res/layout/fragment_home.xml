<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══════════ GREETING CARD ═══════════ -->
        <LinearLayout
            android:id="@+id/greetingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_greeting_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good evening,"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:letterSpacing="-0.02"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:id="@+id/tvRolePill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_role_pill"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/cyan_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.06" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════ FACILITATOR PROMO BANNER ═══════════ -->
        <LinearLayout
            android:id="@+id/promoBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_fac_promo"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/promoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/promo_title"
                android:textColor="@color/orange_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:id="@+id/promoDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/promo_desc"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:layout_marginTop="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPromote"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/promo_button"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:backgroundTint="@color/orange_accent"
                android:textColor="@color/white"
                app:cornerRadius="8dp"
                android:layout_marginTop="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </LinearLayout>

        <!-- ═══════════ SHORTCUT GRID (2×2) ═══════════ -->
        <GridLayout
            android:id="@+id/shortcutGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="16dp"
            android:useDefaultMargins="true">

            <!-- Pending -->
            <LinearLayout
                android:id="@+id/cardPending"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_shortcut_card"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tvPendingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/cyan_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_pending"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- My Average -->
            <LinearLayout
                android:id="@+id/cardAverage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_shortcut_card"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tvAverageScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/orange_accent"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_average"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Submitted -->
            <LinearLayout
                android:id="@+id/cardSubmitted"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_shortcut_card"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tvSubmittedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/green_success"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_submitted"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Needs Attention -->
            <LinearLayout
                android:id="@+id/cardAttention"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_shortcut_card"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tvAttentionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/orange_warning"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_attention"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </GridLayout>

        <!-- ═══════════ RECENT ACTIVITY SECTION ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recent_activity"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/recentActivityContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvRecentEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/recent_empty"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="center" />
        </LinearLayout>

        <!-- ═══════════ QUOTE BOX ═══════════ -->
        <LinearLayout
            android:id="@+id/quoteBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_quote_box"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvQuote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_quote"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:fontStyle="italic"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
