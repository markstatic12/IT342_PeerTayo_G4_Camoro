<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="100dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 2: Assign Participants"
        android:textColor="@color/cyan_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:fontFamily="@font/plus_jakarta_sans" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Who is being evaluated?"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans"
        android:layout_marginTop="8dp" />

    <!-- Evaluators Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="32dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EVALUATORS"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="@font/plus_jakarta_sans" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddEvaluators"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="+ Add Users"
            android:textColor="@color/cyan_primary"
            android:textSize="11sp"
            android:padding="0dp"
            android:textAllCaps="false" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEvaluators"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_glass_card" />

    <!-- Evaluatees Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EVALUATEES"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="@font/plus_jakarta_sans" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddEvaluatees"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="+ Add Users"
            android:textColor="@color/cyan_primary"
            android:textSize="11sp"
            android:padding="0dp"
            android:textAllCaps="false" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEvaluatees"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_glass_card" />

</LinearLayout>
