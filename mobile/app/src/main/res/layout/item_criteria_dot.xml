<?xml version="1.0" encoding="utf-8"?>
<!--
  item_criteria_dot.xml
  Criteria breakdown row using 5 filled/empty dot indicators (1–5 scale).
  Matches the web MyResultsPage right-panel dot visualization (GAP-08).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_card"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Criterion Name + Numeric Score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvCriterionName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/plus_jakarta_sans" />

        <TextView
            android:id="@+id/tvCriterionScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cyan_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvScoreLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="@font/plus_jakarta_sans" />
    </LinearLayout>

    <!-- 5 Dot Indicators (populated programmatically) -->
    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp" />

</LinearLayout>
