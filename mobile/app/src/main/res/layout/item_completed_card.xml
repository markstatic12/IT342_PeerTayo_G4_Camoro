<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_eval_card"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical">

    <!-- Avatar circle -->
    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_user_avatar">

        <TextView
            android:id="@+id/tvInitial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/cyan_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvEvaluatee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Done Badge -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:gravity="center"
        android:text="✓ Done"
        android:textSize="10sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans"
        android:textColor="@color/green_success"
        android:background="@drawable/bg_success_circle"
        android:paddingHorizontal="8dp" />
</LinearLayout>
