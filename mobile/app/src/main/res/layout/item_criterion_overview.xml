<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_glass_card"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/tvCriterionName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Technical Skills"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans" />

    <TextView
        android:id="@+id/tvCriterionDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ability to apply technical knowledge to solve problems effectively."
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:lineSpacingExtra="2dp" />

</LinearLayout>
