<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_card"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Criterion Name + Score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvCriterionName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/plus_jakarta_sans" />

        <TextView
            android:id="@+id/tvCriterionScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cyan_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans" />
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progressDrawable="@drawable/bg_progress_track"
        android:layout_marginTop="6dp" />
</LinearLayout>
