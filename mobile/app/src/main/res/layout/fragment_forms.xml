<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_forms.xml
  GAP-04 FIX:
    • 4-stat strip: Total Forms / Active / Needs Attention / Closed
    • Search bar
    • Filter tabs: All / Active / Needs Attention / Closed
    • Matches web FormsCreatedPage layout
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <!-- ── Header with Create Button ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/forms_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreate"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/forms_create"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:backgroundTint="@color/cyan_primary"
            android:textColor="@color/text_on_cyan"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_create"
            app:iconSize="14dp"
            app:iconTint="@color/text_on_cyan" />
    </LinearLayout>

    <!-- ── 4-Stat Strip ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <!-- Total Forms -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvStatTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/cyan_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forms_stat_total"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/border_card" />

        <!-- Active -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvStatActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/green_success"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forms_stat_active"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/border_card" />

        <!-- Needs Attention -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvStatAttention"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/orange_accent"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forms_stat_attention"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/border_card" />

        <!-- Closed -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvStatClosed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_muted"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forms_stat_closed"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textAllCaps="true"
                android:letterSpacing="0.06" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Search Bar ────────────────────────────────────────────────── -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:hint="Search forms…"
        android:textSize="13sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:background="@drawable/bg_input_field"
        android:paddingHorizontal="14dp"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:singleLine="true"
        android:layout_marginBottom="10dp"
        android:drawableStart="@drawable/ic_assign"
        android:drawablePadding="8dp" />

    <!-- Archive Toggle (GAP-04) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Show Archived"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/plus_jakarta_sans" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchArchived"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- ── Filter Tabs ───────────────────────────────────────────────── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/filter_all"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_on_cyan"
                android:background="@drawable/bg_filter_pill_active"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterActive"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/forms_stat_active"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterAttention"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/forms_stat_attention"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterClosed"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/forms_stat_closed"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="16dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Forms List ────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvForms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_empty_forms"
            app:tint="@color/text_placeholder" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/forms_empty"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</LinearLayout>
