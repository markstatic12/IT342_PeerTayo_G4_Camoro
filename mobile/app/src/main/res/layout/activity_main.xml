<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Brand Logo -->
    <LinearLayout
        android:id="@+id/brandLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4xl"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/brand_logo_description"
            android:src="@drawable/ic_peertayo_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="PeerTayo"
            android:textSize="@dimen/font_size_2xl"
            android:textStyle="bold"
            android:textColor="@color/blue_primary"
            android:fontFamily="@font/plus_jakarta_sans" />
    </LinearLayout>

    <!-- Welcome Heading -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome!"
        android:textSize="@dimen/font_size_xl"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/plus_jakarta_sans"
        android:layout_marginTop="@dimen/space_4xl"
        app:layout_constraintTop_toBottomOf="@id/brandLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- User Email -->
    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="user@example.com"
        android:textSize="@dimen/font_size_sm"
        android:textColor="@color/text_secondary"
        android:fontFamily="@font/plus_jakarta_sans"
        android:layout_marginTop="@dimen/space_md"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="You have successfully logged in to PeerTayo!\n\nThis is your dashboard. Navigate through the app to access evaluations, feedback, and more."
        android:textSize="@dimen/font_size_sm"
        android:textColor="@color/text_muted"
        android:textAlignment="center"
        android:fontFamily="@font/plus_jakarta_sans"
        android:layout_marginTop="@dimen/space_3xl"
        app:layout_constraintTop_toBottomOf="@id/tvEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Logout Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/AuthButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Sign Out"
        android:textSize="@dimen/button_text_size"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans"
        android:layout_marginBottom="@dimen/space_4xl"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
