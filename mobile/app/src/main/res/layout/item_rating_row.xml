<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_card"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- Criterion Name -->
    <TextView
        android:id="@+id/tvCriterionName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans" />

    <!-- Criterion Description -->
    <TextView
        android:id="@+id/tvCriterionDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:layout_marginTop="2dp"
        android:visibility="gone" />

    <!-- Rating Buttons 1-5 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/btnRate1"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_rating_btn"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnRate2"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="2"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_rating_btn"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnRate3"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="3"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_rating_btn"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnRate4"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="4"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_rating_btn"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnRate5"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="5"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_rating_btn"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
