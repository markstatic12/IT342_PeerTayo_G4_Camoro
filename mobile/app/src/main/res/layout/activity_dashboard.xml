<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <!-- ═══════════ TOP BAR — matches web topbar style ═══════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:background="@color/bg_primary"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_peertayo_logo"
            android:contentDescription="@string/brand_logo_description" />

        <TextView
            android:id="@+id/tvBrandName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:letterSpacing="-0.02"
            android:layout_marginStart="9dp" />

        <!-- Notification Bell -->
        <FrameLayout
            android:id="@+id/btnNotifications"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_btn"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_notif"
                app:tint="@color/text_secondary"
                android:contentDescription="@string/notif_desc" />

            <View
                android:id="@+id/notifDot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_dot_cyan"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Settings -->
        <FrameLayout
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_icon_btn"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_secondary"
                android:contentDescription="@string/settings_desc" />
        </FrameLayout>
    </LinearLayout>

    <!-- ═══════════ FRAGMENT CONTAINER ═══════════ -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="100dp" />

    <!-- ═══════════ BOTTOM NAVIGATION — Floating Premium Style ═══════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_floating_nav"
        app:itemIconTint="@color/bottom_nav_item_colors"
        app:itemTextColor="@color/bottom_nav_item_colors"
        app:labelVisibilityMode="unlabeled"
        app:itemRippleColor="@color/blue_glow"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="12dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
