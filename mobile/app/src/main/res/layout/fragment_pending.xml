<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvPendingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/cyan_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pending_stat_count"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:letterSpacing="0.06"
                android:textAllCaps="true" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/border_card" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvUrgentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/orange_accent"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pending_stat_urgent"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:letterSpacing="0.06"
                android:textAllCaps="true" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/border_card" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvDoneCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/green_success"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pending_stat_month"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:letterSpacing="0.06"
                android:textAllCaps="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Filter Pills -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:id="@+id/filterRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/filter_all"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_on_cyan"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterUrgent"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/filter_urgent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <!-- "Missed" matches web's third filter tab -->
            <TextView
                android:id="@+id/filterWeek"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/filter_missed"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="16dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Evaluation Cards List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPending"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_empty_check"
            app:tint="@color/text_placeholder" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pending_empty"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</LinearLayout>
