<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="100dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 2: Criteria Overview"
        android:textColor="@color/cyan_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:fontFamily="@font/plus_jakarta_sans" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Review the 10 evaluation metrics."
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="These criteria are used to measure peer performance across all evaluations."
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/plus_jakarta_sans" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCriteria"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="20dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp" />

</LinearLayout>
