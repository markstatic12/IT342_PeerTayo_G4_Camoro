<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_feature_card"
    android:padding="16dp">

    <!-- Icon + Title Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- Icon container — matches web auth-feature-icon -->
        <FrameLayout
            android:layout_width="@dimen/feature_icon_size"
            android:layout_height="@dimen/feature_icon_size"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_feature_icon">

            <ImageView
                android:id="@+id/ivFeatureIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_default"
                android:contentDescription="Feature icon" />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvFeatureTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Feature Title"
            style="@style/FeatureTitleStyle" />

    </LinearLayout>

    <!-- Description -->
    <TextView
        android:id="@+id/tvFeatureDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="58dp"
        android:text="Feature description goes here and explains what this feature does."
        style="@style/FeatureDescStyle" />

</LinearLayout>
