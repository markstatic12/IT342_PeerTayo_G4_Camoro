<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════════════════════
         BASE APP THEME — Dark, matches web #080b14 background
         ═══════════════════════════════════════════════════════════════════ -->
    <style name="Base.Theme.Peertayomobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Window & system bars -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/bg_primary</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_peertayo_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">@android:color/transparent</item>
        <item name="android:postSplashScreenTheme" tools:targetApi="31">@style/Theme.Peertayomobile</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <!-- Smooth transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/fade</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>

        <!-- Material color roles -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorPrimaryContainer">@color/blue_dim</item>
        <item name="colorSecondary">@color/blue_light</item>
        <item name="colorTertiary">@color/green_success</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/red_error</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Typography -->
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>

        <!-- TextInputLayout global styling -->
        <item name="textInputStyle">@style/FormInputLayout</item>
    </style>

    <style name="Theme.Peertayomobile" parent="Base.Theme.Peertayomobile" />

    <style name="Theme.Peertayomobile.NoActionBar" parent="Theme.Peertayomobile">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Peertayomobile.Splash" parent="Theme.Peertayomobile.NoActionBar" />


    <!-- ═══════════════════════════════════════════════════════════════════
         FORM INPUT LAYOUT — Filled/Outlined dark style matching web
         ═══════════════════════════════════════════════════════════════════ -->
    <style name="FormInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="boxStrokeColor">@color/input_stroke_colors</item>
        <item name="boxBackgroundColor">#0A111F</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColorHint">@color/text_dim</item>
        <item name="startIconTint">@color/text_dim</item>
        <item name="endIconTint">@color/text_dim</item>
        <item name="boxCornerRadiusTopStart">9dp</item>
        <item name="boxCornerRadiusTopEnd">9dp</item>
        <item name="boxCornerRadiusBottomStart">9dp</item>
        <item name="boxCornerRadiusBottomEnd">9dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="hintAnimationEnabled">true</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════════
         PRIMARY BUTTON — Blue gradient, matches web shimmer button
         ═══════════════════════════════════════════════════════════════════ -->
    <style name="AuthButton" parent="Widget.Material3.Button">
        <item name="android:paddingStart">@dimen/button_padding_h</item>
        <item name="android:paddingEnd">@dimen/button_padding_h</item>
        <item name="android:paddingTop">@dimen/button_padding_v</item>
        <item name="android:paddingBottom">@dimen/button_padding_v</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="backgroundTint">@color/blue_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/button_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════
         OUTLINED BUTTON — Google sign-in, matches web social button
         ═══════════════════════════════════════════════════════════════════ -->
    <style name="SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="strokeColor">@color/border_normal</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:paddingStart">@dimen/button_padding_h</item>
        <item name="android:paddingEnd">@dimen/button_padding_h</item>
        <item name="android:paddingTop">@dimen/button_padding_v</item>
        <item name="android:paddingBottom">@dimen/button_padding_v</item>
        <item name="android:textSize">@dimen/button_text_size</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="backgroundTint">@color/bg_surface</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════
         LANDING PAGE BUTTON — Get Started (pill, blue gradient)
         ═══════════════════════════════════════════════════════════════════ -->
    <style name="LandingPrimaryButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">28dp</item>
        <item name="backgroundTint">@color/blue_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="elevation">8dp</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════
         LANDING GHOST BUTTON — See How It Works
         ═══════════════════════════════════════════════════════════════════ -->
    <style name="LandingGhostButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">28dp</item>
        <item name="strokeColor">@color/border_normal</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="elevation">0dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════════
         TYPE STYLES — Auth forms
         ═══════════════════════════════════════════════════════════════════ -->
    <style name="HeadingLarge">
        <item name="android:textSize">@dimen/font_size_2xl</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="HeadingMedium">
        <item name="android:textSize">@dimen/font_size_xl</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="BodyText">
        <item name="android:textSize">@dimen/font_size_base</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="BodyTextSmall">
        <item name="android:textSize">@dimen/font_size_sm</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="CaptionText">
        <item name="android:textSize">@dimen/font_size_xs</item>
        <item name="android:textColor">@color/text_dim</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="ErrorText">
        <item name="android:textSize">@dimen/font_size_xs</item>
        <item name="android:textColor">@color/red_error_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="DividerText">
        <item name="android:textSize">@dimen/divider_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_dim</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="LinkText">
        <item name="android:textColor">@color/blue_light</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="FormLabel">
        <item name="android:textSize">@dimen/text_label_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

</resources>