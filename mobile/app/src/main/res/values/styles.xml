        <item name="android:textColor">@color/blue_light</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="BadgeLabelStyle" parent="Widget.AppCompat.TextView">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/blue_light</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

</resources>
