<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_peertayo_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_peertayo_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Peertayomobile"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        
        <activity
            android:name=".landing.LandingActivity"
            android:exported="true"
            android:theme="@style/Theme.Peertayomobile.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".auth.login.LoginActivity"
            android:theme="@style/Theme.Peertayomobile.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".auth.register.RegisterActivity"
            android:theme="@style/Theme.Peertayomobile.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".MainActivity" />

        <activity
            android:name=".dashboard.DashboardActivity"
            android:theme="@style/Theme.Peertayomobile.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".evaluation.EvaluateFormActivity"
            android:theme="@style/Theme.Peertayomobile.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".evaluation.CreateEvaluationActivity"
            android:theme="@style/Theme.Peertayomobile.CreateEvaluation"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".notification.NotificationActivity"
            android:theme="@style/Theme.Peertayomobile.NoActionBar" />

        <activity
            android:name=".settings.SettingsActivity"
            android:theme="@style/Theme.Peertayomobile.NoActionBar" />
        <activity
            android:name=".evaluation.EvaluationResultsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.PeerTayo" />
    </application>

</manifest>
